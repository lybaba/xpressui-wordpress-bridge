{
  "name": "@lybaba/xpressui",
  "version": "1.0.1",
  "repository": "https://github.com/lybaba/xpressui",
  "description": "Schema-driven web components for forms and post UIs",
  "main": "./lib/index.js",
  "module": "./dist/xpressui.mjs",
  "types": "./lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./dist/xpressui.mjs",
      "require": "./lib/index.js",
      "default": "./dist/xpressui.mjs"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "/lib",
    "/dist"
  ],
  "scripts": {
    "prestart": "npm run build:css",
    "start": "vite",
    "prebuild": "npm run build:css",
    "build:css": "tailwindcss -i ./src/input.css -o ./index.css",
    "build:dist": "vite build --sourcemap",
    "build:dist:light": "XPRESSUI_RUNTIME_TIER=light vite build --sourcemap",
    "build": "node ./scripts/clean-build.mjs && tsc && npm run build:dist && npm run build:dist:light && tsc --project ./lib.tsconfig.json",
    "pages:prepare": "npm run build && node ./scripts/prepare-pages.mjs",
    "release:check": "npm run build && npm run verify:dist && npm run verify:lib && npm pack --dry-run --cache ./.npm-cache",
    "verify:dist": "node ./scripts/verify-dist.mjs",
    "verify:lib": "node ./scripts/verify-lib.mjs",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-errors": "^3.0.0",
    "ajv-formats": "^3.0.1",
    "final-form": "^5.0.0",
    "lodash": "^4.17.23",
    "slugify": "^1.6.6"
  },
  "overrides": {
    "@babel/runtime": "^7.26.10"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.3",
    "daisyui": "^5.5.19",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
